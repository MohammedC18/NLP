# -------- IMPROVED TRANSITION-BASED PARSER --------

def transition_parser(words):
    stack = ["ROOT"]
    buffer = words.copy()
    arcs = []

    while buffer or len(stack) > 1:
        
        # SHIFT if stack too small
        if len(stack) < 2:
            stack.append(buffer.pop(0))
        
        # If buffer not empty → SHIFT
        elif buffer:
            stack.append(buffer.pop(0))
        
        # Apply RIGHT-ARC (simple rule: previous word is head)
        else:
            head = stack[-2]
            dependent = stack[-1]
            arcs.append((head, dependent))
            stack.pop()

    return arcs


# -------- USER INPUT --------
sentence = input("Enter a sentence: ").lower().split()

# Run parser
dependencies = transition_parser(sentence)

# -------- OUTPUT --------
print("\nDependency Relations (Head -> Dependent):")
for head, dep in dependencies:
    print(f"{head} -> {dep}")


