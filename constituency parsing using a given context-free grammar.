import nltk
from nltk import CFG
from nltk.parse import ChartParser
import matplotlib.pyplot as plt

# -------- DEFINE GRAMMAR --------
grammar = CFG.fromstring("""
S -> NP VP
NP -> Det N | Det Adj N | 'i'
VP -> V NP | V
Det -> 'a' | 'the' | 'my'
N -> 'cat' | 'dog' | 'man' | 'telescope'
Adj -> 'big' | 'small'
V -> 'saw' | 'ate' | 'loved'
""")

# Create parser
parser = ChartParser(grammar)

# -------- USER INPUT --------
sentence = input("Enter a sentence: ").lower().split()

# -------- PARSING + VISUALIZATION --------
trees = list(parser.parse(sentence))

if len(trees) == 0:
    print("No parse tree found. Check grammar and sentence.")
else:
    print("Parse Tree:")
    trees[0].pretty_print()   # text tree (better formatted)

    # Draw graphical tree (opens window)
trees[0].pretty_print()

